# Скопируй этот файл в .env и заполни реальными значениями.
# .env коммитить НЕЛЬЗЯ — он в .gitignore.

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Telegram ID администратора (твой личный ID, не ID бота)
# Узнать свой ID: напиши боту @userinfobot
ADMIN_TELEGRAM_ID=

# Путь к файлу базы данных SQLite (относительно корня проекта)
DB_PATH=data/bot.db

# Путь к JSON с тестовыми вопросами для первичного сидинга
SEED_QUESTIONS_PATH=data/questions_seed.json

# Дата, на которую актуальна правовая база. Показывается в дисклеймере.
# Формат: YYYY-MM-DD
LAW_BASE_DATE=2026-05-20

# Уровень логирования: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Опционально: HTTPS-прокси для Telegram API.
# Нужен, если хостинг блокирует исходящий трафик к api.telegram.org
# (типичная ситуация для российских VPS). Формат: http://user:pass@host:port
# Оставь пустым, если прокси не нужен.
PROXY_URL=
